{
  "$schema": "https://opencode.ai/config.json",
  // NOTE: For WSL, ensure systemd-timesyncd is disabled.
  // https://github.com/anomalyco/opencode/issues/5361#issuecomment-3784940613
  // Permission wildcards allow for ` *` at the end to match the command itself (eg. `ls *` matches `ls`)
  "permission": {
    "bash": {
      "*": "ask",
      "cargo build *": "allow",
      "cargo bench *": "allow",
      "* cargo bench *": "allow",
      "cargo check *": "allow",
      "cargo clippy *": "allow",
      "cargo doc *": "allow",
      "cargo fmt *": "allow",
      "cargo info *": "allow",
      "cargo llvm-cov *": "allow",
      "cargo metadata *": "allow",
      "cargo run *": "allow",
      "cargo rustc *": "allow",
      "cargo rustdoc *": "allow",
      "cargo search *": "allow",
      "cargo test *": "allow",
      "cargo tree *": "allow",
      "cat *": "allow",
      "command -v *": "allow",
      "curl *": "allow",
      "cut *": "allow",
      "date *": "allow",
      "echo *": "allow",
      "exit *": "allow",
      "find *": "allow",
      "git add *": "allow",
      "git apply *": "allow",
      // We're being conservative with git-branch here to avoid deleting things
      "git branch --list *": "allow",
      "git branch --list": "allow",
      "git branch --show-current": "allow",
      "git branch": "allow",
      "git blame *": "allow",
      "git cat-file *": "allow",
      "git check-ignore *": "allow",
      "git checkout *": "allow",
      "git commit *": "allow",
      "git describe *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git ls-files *": "allow",
      "git ls-tree *": "allow",
      "git merge-base *": "allow",
      "git restore --staged": "allow",
      "git rev-parse *": "allow",
      "git rev-list *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "go build *": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "mktemp *": "allow",
      "mv *": "allow",
      "nl *": "allow",
      "npm build *": "allow",
      "npm install *": "allow",
      "npm lint *": "allow",
      "npm run *": "allow",
      "npm test *": "allow",
      "npm uninstall *": "allow",
      "npm update *": "allow",
      "pnpm -C * build *": "allow",
      "pnpm -C * lint *": "allow",
      "pnpm -C * run *": "allow",
      "pnpm -C * test *": "allow",
      "pnpm -C * test *": "allow",
      "pnpm build *": "allow",
      "pnpm install *": "allow",
      "pnpm lint *": "allow",
      "pnpm run *": "allow",
      "pnpm test *": "allow",
      "pnpm uninstall *": "allow",
      "pnpm update *": "allow",
      "printf *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "rustc *": "allow",
      "rustfmt *": "allow",
      "sed": "allow",
      "sha256sum *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "true": "allow",
      "wc *": "allow",
      "which *": "allow",
    },
    "edit": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.cargo/registry/*": "allow",
      "/var/cache/cargo/*": "allow",
    },
    "grep": {
      "*": "allow",
      "~/.cargo/registry/*": "allow",
      "/var/cache/cargo/*": "allow",
    },
    "glob": {
      "*": "allow",
      "~/.cargo/registry/*": "allow",
      "/var/cache/cargo/*": "allow",
    },
    "list": {
      "*": "allow",
      "~/.cargo/registry/*": "allow",
      "/var/cache/cargo/*": "allow",
    },
  },
  "theme": "system",
  "lsp": false,
  // Explicitly enable compaction
  "compaction": {
    "auto": true,
    "prune": true
  },
  "plugin": [],
  "experimental": {
    "disable_paste_summary": true,
  },
  "disabled_providers": ["llama-swap", "cursor"],
  "provider": {
    "llama-swap": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-swap (local)",
      "options": {
        "baseURL": "http://10.42.40.71:8989/v1"
      },
      "models": {
        "Qwen3-Coder": {
          "name": "Qwen3-Coder: A3B-30B",
          "limit": {
            "context": 102400,
            "output": 65536
          }
        },
        "Qwen3": {
          "name": "Qwen3: 32B",
          "limit": {
            "context": 102400,
            "output": 65536
          }
        }
      }
    }
  }
}
