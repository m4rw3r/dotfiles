#compdef alacritty_theme

local config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
local theme_dir="$config_home/alacritty/themes"

local -a themes
themes=(${theme_dir}/*.toml(N:t:r))

_arguments -s -S \
  '1:command or theme:->cmd' \
  '*::args:->extra' && return 0

case $state in
  cmd)
    _values 'alacritty theme command' \
      list \
      help \
      $themes
    ;;
esac
